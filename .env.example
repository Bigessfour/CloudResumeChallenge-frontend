# Optional project .env (never commit .env). Primary secrets use machine-scope env vars.
# Windows: System Properties → Environment Variables → User or System variables.

# Syncfusion MCP (@syncfusion/typescript-assistant) — official name:
# Syncfusion_API_Key=

# EJ2 license — then run: npm run syncfusion:setup
# https://ej2.syncfusion.com/documentation/licensing/license-key-registration
# SYNCFUSION_LICENSE=
# Or use syncfusion-license.txt (copy from syncfusion-license.txt.example)

# VISITOR_COUNTER_API_URL=
