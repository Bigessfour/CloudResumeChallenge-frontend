{
  "name": "cloud-resume-challenge",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Cloud Resume Challenge — static Syncfusion EJ2 frontend",
  "scripts": {
    "lint": "eslint js/",
    "lint:fix": "eslint js/ --fix",
    "format": "prettier --write \"**/*.{html,css,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{html,css,js,json,md}\"",
    "ci": "npm run lint && npm run format:check",
    "syncfusion:license": "node scripts/syncfusion-license-from-env.mjs",
    "syncfusion:activate": "npx syncfusion-license activate",
    "syncfusion:setup": "node scripts/syncfusion-setup.mjs",
    "syncfusion:provision": "node scripts/syncfusion-provision-from-system.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "globals": "^16.2.0",
    "prettier": "^3.5.3"
  }
}
